# Forge platform environment variables
# Copy to `.env` and fill in secrets. Never commit `.env`.

# --- Core API ---
ANTHROPIC_API_KEY=
ADMIN_KEY=forge-admin-2026
DATABASE_URL=postgresql://forge:forge@localhost:5432/forge
REDIS_URL=redis://localhost:6379
PORT=8090
HOST=0.0.0.0
FORGE_HOST=http://localhost:8090

# --- GitHub App / auto-deploy (forge_bot) ---
# Shared secret configured on the GitHub App webhook page. Verified with
# HMAC-SHA256 against each incoming X-Hub-Signature-256 header.
GITHUB_WEBHOOK_SECRET=
# Token used by the deployer to post commit statuses back to GitHub and to
# clone private repos. Use a GitHub App installation token in production;
# a fine-grained PAT works for local dev.
GITHUB_TOKEN=
# Base URL the deployer POSTs to (defaults to localhost for dev).
FORGE_API_URL=http://localhost:8090
# Admin key passed by the deployer on X-Admin-Key. Usually matches ADMIN_KEY.
FORGE_API_KEY=
# Webhook listener port. Must NOT be 8091 (that port is reserved for the
# test dashboard). Default 8093.
FORGE_WEBHOOK_PORT=8093

# --- ForgeData / Salesforce connector ---
# When any of USERNAME/PASSWORD/TOKEN are missing, every /api/forgedata/*
# route returns {"error": "Salesforce not configured", "configured": false}.
SALESFORCE_USERNAME=
SALESFORCE_PASSWORD=
SALESFORCE_TOKEN=
SALESFORCE_DOMAIN=login.salesforce.com
